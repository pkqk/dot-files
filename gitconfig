[core]
  excludesfile = /Volumes/HD/Users/adamjohnson/.dot-files.git/gitignore
[user]
	name = Adam Johnson
	email = adam@pkqk.net
[alias]
  g = grep -n
  st = status
  ci = commit
  cia = commit -a
  co = checkout
  cob = checkout -b
  d = diff
  pu = push
  pl = pull
  unmerge = reset --hard ORIG_HEAD
  cloner = clone -o reevoo
[color]
  branch = auto
  diff = auto
  status = auto
  interactive = auto
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green
[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold
[color "status"]
  added = yellow
  changed = green
  untracked = cyan
[web]
  browser = open
[branch]
	autosetupmerge = true
[status]
  submodulesummary = true
[url "git@code:"]
  insteadOf = reevoo:
[url "git@github.com:pkqk/"]
  insteadOf = github:
[push]
	default = tracking
